{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "_generator": {
      "name": "bicep",
      "version": "0.42.1.51946",
      "templateHash": "2679051581931286754"
    }
  },
  "parameters": {
    "baseName": {
      "type": "string",
      "minLength": 3,
      "maxLength": 18,
      "metadata": {
        "description": "Base name for all Azure resources (lowercase, 3-18 chars, no spaces)."
      }
    },
    "location": {
      "type": "string",
      "defaultValue": "[resourceGroup().location]",
      "metadata": {
        "description": "Azure region. Any region where Microsoft Foundry + Azure Bot Service are available."
      }
    },
    "foundryModel": {
      "type": "string",
      "defaultValue": "gpt-4.1",
      "allowedValues": [
        "gpt-4.1",
        "gpt-4.1-mini",
        "gpt-4o",
        "gpt-4o-mini",
        "gpt-5",
        "gpt-5-mini"
      ],
      "metadata": {
        "description": "Foundry text model used by the IT Assistant."
      }
    },
    "mcsAgentName": {
      "type": "string",
      "defaultValue": "Microsoft Learn Assistant",
      "metadata": {
        "description": "Copilot Studio agent display name — must match the MCS agent created by the deploymentScript."
      }
    },
    "powerPlatformEnvironmentUrl": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "URL of the target Power Platform environment (e.g. https://contoso.crm.dynamics.com). Leave empty to skip MCS provisioning and create the agent manually with copilot-studio-agent/create-agent.ps1."
      }
    },
    "entraTenantId": {
      "type": "string",
      "defaultValue": "[tenant().tenantId]",
      "metadata": {
        "description": "Entra tenant ID. Defaults to the current Azure subscription tenant."
      }
    },
    "powerPlatformSpnClientId": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "Entra SPN client ID registered as an Application User (Dataverse System Admin) in the PP env. Leave empty to skip."
      }
    },
    "powerPlatformSpnClientSecret": {
      "type": "securestring",
      "defaultValue": "",
      "metadata": {
        "description": "Secret for the SPN. Leave empty to skip."
      }
    },
    "secretReaderObjectId": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "Object ID of the user / group that needs read access to the Key Vault secret (usually the deploying user). Defaults to the deploying principal."
      }
    }
  },
  "variables": {
    "foundryName": "[format('{0}-foundry', parameters('baseName'))]",
    "foundryCustomDomain": "[toLower(format('{0}-foundry', parameters('baseName')))]",
    "keyVaultName": "[toLower(format('{0}-kv', parameters('baseName')))]",
    "appInsightsName": "[format('{0}-insights', parameters('baseName'))]",
    "logAnalyticsName": "[format('{0}-logs', parameters('baseName'))]",
    "provisionMcs": "[and(and(not(empty(parameters('powerPlatformEnvironmentUrl'))), not(empty(parameters('powerPlatformSpnClientId')))), not(empty(parameters('powerPlatformSpnClientSecret'))))]",
    "keyVaultSecretsOfficerRoleId": "b86a8fe4-44ce-4948-aee5-eccb2c155cd7",
    "keyVaultSecretsUserRoleId": "4633458b-17de-408a-b874-0445c86b69e6",
    "directLineSecretName": "mcs-directline-secret"
  },
  "resources": [
    {
      "type": "Microsoft.CognitiveServices/accounts",
      "apiVersion": "2024-10-01",
      "name": "[variables('foundryName')]",
      "location": "[parameters('location')]",
      "kind": "AIServices",
      "sku": {
        "name": "S0"
      },
      "identity": {
        "type": "SystemAssigned"
      },
      "properties": {
        "customSubDomainName": "[variables('foundryCustomDomain')]",
        "publicNetworkAccess": "Enabled",
        "disableLocalAuth": false
      }
    },
    {
      "type": "Microsoft.OperationalInsights/workspaces",
      "apiVersion": "2023-09-01",
      "name": "[variables('logAnalyticsName')]",
      "location": "[parameters('location')]",
      "properties": {
        "sku": {
          "name": "PerGB2018"
        },
        "retentionInDays": 30
      }
    },
    {
      "type": "Microsoft.Insights/components",
      "apiVersion": "2020-02-02",
      "name": "[variables('appInsightsName')]",
      "location": "[parameters('location')]",
      "kind": "web",
      "properties": {
        "Application_Type": "web",
        "WorkspaceResourceId": "[resourceId('Microsoft.OperationalInsights/workspaces', variables('logAnalyticsName'))]"
      },
      "dependsOn": [
        "[resourceId('Microsoft.OperationalInsights/workspaces', variables('logAnalyticsName'))]"
      ]
    },
    {
      "type": "Microsoft.KeyVault/vaults",
      "apiVersion": "2024-04-01-preview",
      "name": "[variables('keyVaultName')]",
      "location": "[parameters('location')]",
      "properties": {
        "tenantId": "[subscription().tenantId]",
        "sku": {
          "family": "A",
          "name": "standard"
        },
        "enableRbacAuthorization": true,
        "softDeleteRetentionInDays": 7,
        "enablePurgeProtection": false,
        "publicNetworkAccess": "Enabled"
      }
    },
    {
      "condition": "[not(empty(parameters('secretReaderObjectId')))]",
      "type": "Microsoft.Authorization/roleAssignments",
      "apiVersion": "2022-04-01",
      "scope": "[resourceId('Microsoft.KeyVault/vaults', variables('keyVaultName'))]",
      "name": "[guid(resourceId('Microsoft.KeyVault/vaults', variables('keyVaultName')), variables('keyVaultSecretsUserRoleId'), parameters('secretReaderObjectId'))]",
      "properties": {
        "roleDefinitionId": "[subscriptionResourceId('Microsoft.Authorization/roleDefinitions', variables('keyVaultSecretsUserRoleId'))]",
        "principalId": "[parameters('secretReaderObjectId')]",
        "principalType": "User"
      },
      "dependsOn": [
        "[resourceId('Microsoft.KeyVault/vaults', variables('keyVaultName'))]"
      ]
    },
    {
      "condition": "[variables('provisionMcs')]",
      "type": "Microsoft.ManagedIdentity/userAssignedIdentities",
      "apiVersion": "2023-01-31",
      "name": "[format('{0}-deploy-mi', parameters('baseName'))]",
      "location": "[parameters('location')]"
    },
    {
      "condition": "[variables('provisionMcs')]",
      "type": "Microsoft.Authorization/roleAssignments",
      "apiVersion": "2022-04-01",
      "scope": "[resourceId('Microsoft.KeyVault/vaults', variables('keyVaultName'))]",
      "name": "[guid(resourceId('Microsoft.KeyVault/vaults', variables('keyVaultName')), variables('keyVaultSecretsOfficerRoleId'), format('{0}-deploy-mi', parameters('baseName')))]",
      "properties": {
        "roleDefinitionId": "[subscriptionResourceId('Microsoft.Authorization/roleDefinitions', variables('keyVaultSecretsOfficerRoleId'))]",
        "principalId": "[reference(resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', format('{0}-deploy-mi', parameters('baseName'))), '2023-01-31').principalId]",
        "principalType": "ServicePrincipal"
      },
      "dependsOn": [
        "[resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', format('{0}-deploy-mi', parameters('baseName')))]",
        "[resourceId('Microsoft.KeyVault/vaults', variables('keyVaultName'))]"
      ]
    },
    {
      "condition": "[variables('provisionMcs')]",
      "type": "Microsoft.Resources/deploymentScripts",
      "apiVersion": "2023-08-01",
      "name": "[format('{0}-deploy-mcs', parameters('baseName'))]",
      "location": "[parameters('location')]",
      "kind": "AzurePowerShell",
      "identity": {
        "type": "UserAssigned",
        "userAssignedIdentities": {
          "[format('{0}', resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', format('{0}-deploy-mi', parameters('baseName'))))]": {}
        }
      },
      "properties": {
        "azPowerShellVersion": "11.5",
        "retentionInterval": "PT1H",
        "timeout": "PT30M",
        "cleanupPreference": "OnSuccess",
        "environmentVariables": [
          {
            "name": "PP_ENV_URL",
            "value": "[parameters('powerPlatformEnvironmentUrl')]"
          },
          {
            "name": "SP_TENANT",
            "value": "[parameters('entraTenantId')]"
          },
          {
            "name": "SP_CLIENT_ID",
            "value": "[parameters('powerPlatformSpnClientId')]"
          },
          {
            "name": "SP_SECRET",
            "secureValue": "[parameters('powerPlatformSpnClientSecret')]"
          },
          {
            "name": "AGENT_NAME",
            "value": "[parameters('mcsAgentName')]"
          },
          {
            "name": "SCHEMA_NAME",
            "value": "microsoft_learn_assistant"
          },
          {
            "name": "KV_NAME",
            "value": "[variables('keyVaultName')]"
          },
          {
            "name": "SECRET_NAME",
            "value": "[variables('directLineSecretName')]"
          }
        ],
        "scriptContent": "      $ErrorActionPreference = 'Stop'\n\n      Write-Host \"=== Installing pac CLI ===\" -ForegroundColor Cyan\n      try { dotnet tool install --global Microsoft.PowerApps.CLI.Tool | Out-Null } catch { }\n      $env:PATH = \"$env:PATH\" + [IO.Path]::PathSeparator + \"$HOME/.dotnet/tools\"\n\n      Write-Host \"`n=== Authenticating pac with SPN ===\" -ForegroundColor Cyan\n      pac auth create `\n        --name 'oneclick' `\n        --tenant \"$env:SP_TENANT\" `\n        --applicationId \"$env:SP_CLIENT_ID\" `\n        --clientSecret \"$env:SP_SECRET\" `\n        --environment \"$env:PP_ENV_URL\"\n\n      Write-Host \"`n=== Writing agent.yaml ===\" -ForegroundColor Cyan\n      $agentYaml = @\"\nschemaVersion: \"1.0\"\nkind: DeclarativeAgent\nname: \"$env:AGENT_NAME\"\ndescription: Answers Microsoft product and IT-pro questions using Microsoft Learn.\ninstructions: |\n  You are the Microsoft Learn Assistant. Every answer must be grounded in\n  results from the Microsoft Learn MCP tool. Call microsoft_docs_search first,\n  optionally follow up with microsoft_docs_fetch. Cite Learn article titles\n  inline. Keep answers under 6 sentences.\naiSettings:\n  generativeMode: enabled\n  temperature: 0.3\ntools:\n  - kind: ModelContextProtocolTool\n    name: \"Microsoft Learn MCP\"\n    server:\n      transport: streamableHttp\n      url: \"https://learn.microsoft.com/api/mcp\"\n      authentication:\n        type: none\nchannels:\n  directLine:\n    enabled: true\n  microsoftTeams:\n    enabled: false\n\"@\n      Set-Content -Path ./agent.yaml -Value $agentYaml -Encoding UTF8\n\n      Write-Host \"`n=== Creating agent ===\" -ForegroundColor Cyan\n      $created = $false\n      try {\n        pac copilot create --file ./agent.yaml --name \"$env:AGENT_NAME\" --schema-name \"$env:SCHEMA_NAME\"\n        if ($LASTEXITCODE -eq 0) { $created = $true }\n      } catch { }\n      if (-not $created) {\n        pac copilot new --name \"$env:AGENT_NAME\" --schema-name \"$env:SCHEMA_NAME\"\n        pac copilot update --schema-name \"$env:SCHEMA_NAME\" --file ./agent.yaml\n      }\n\n      Write-Host \"`n=== Publishing ===\" -ForegroundColor Cyan\n      pac copilot publish --schema-name \"$env:SCHEMA_NAME\"\n\n      Write-Host \"`n=== Enabling Direct Line ===\" -ForegroundColor Cyan\n      pac copilot channel enable --schema-name \"$env:SCHEMA_NAME\" --channel directLine\n      $secretJson = pac copilot channel show-secret --schema-name \"$env:SCHEMA_NAME\" --channel directLine --output json\n      $secret = ($secretJson | ConvertFrom-Json).secret\n      if (-not $secret) { throw 'Failed to capture Direct Line secret.' }\n\n      Write-Host \"`n=== Writing secret to Key Vault ===\" -ForegroundColor Cyan\n      az login --identity | Out-Null\n      az keyvault secret set `\n        --vault-name \"$env:KV_NAME\" `\n        --name \"$env:SECRET_NAME\" `\n        --value \"$secret\" | Out-Null\n\n      $DeploymentScriptOutputs = @{\n        agentName  = $env:AGENT_NAME\n        schemaName = $env:SCHEMA_NAME\n        secretUri  = \"https://$env:KV_NAME.vault.azure.net/secrets/$env:SECRET_NAME\"\n      }\n\n      Write-Host \"`n=== Done ===\" -ForegroundColor Green\n    "
      },
      "dependsOn": [
        "[resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', format('{0}-deploy-mi', parameters('baseName')))]",
        "[extensionResourceId(resourceId('Microsoft.KeyVault/vaults', variables('keyVaultName')), 'Microsoft.Authorization/roleAssignments', guid(resourceId('Microsoft.KeyVault/vaults', variables('keyVaultName')), variables('keyVaultSecretsOfficerRoleId'), format('{0}-deploy-mi', parameters('baseName'))))]",
        "[resourceId('Microsoft.KeyVault/vaults', variables('keyVaultName'))]"
      ]
    }
  ],
  "outputs": {
    "foundryName": {
      "type": "string",
      "value": "[variables('foundryName')]"
    },
    "foundryEndpoint": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.CognitiveServices/accounts', variables('foundryName')), '2024-10-01').endpoint]"
    },
    "foundryResourceId": {
      "type": "string",
      "value": "[resourceId('Microsoft.CognitiveServices/accounts', variables('foundryName'))]"
    },
    "keyVaultName": {
      "type": "string",
      "value": "[variables('keyVaultName')]"
    },
    "keyVaultUri": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.KeyVault/vaults', variables('keyVaultName')), '2024-04-01-preview').vaultUri]"
    },
    "directLineSecretName": {
      "type": "string",
      "value": "[variables('directLineSecretName')]"
    },
    "mcsProvisioned": {
      "type": "bool",
      "value": "[variables('provisionMcs')]"
    },
    "foundryModel": {
      "type": "string",
      "value": "[parameters('foundryModel')]"
    }
  }
}