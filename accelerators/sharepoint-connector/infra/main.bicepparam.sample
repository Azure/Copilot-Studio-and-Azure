using './main.bicep'

// ============================================================================
// The ONLY five values a deployer needs to supply.
// Everything else (Search SKU, Foundry, Document Intelligence, Key Vault,
// backup schedule, concurrency, processing modes, file extensions, etc.)
// is created / defaulted inside main.bicep.
// ============================================================================

// Resource-name prefix (3–16 chars, lowercase letters / digits / hyphens).
// A short uniqueness hash is appended automatically where Azure demands
// globally-unique names (Search / Foundry / DocIntel / Storage / Key Vault).
param baseName = 'sp-indexer'

// Leave empty to use the resource group's region, or pin to a specific
// Azure AI Vision multimodal-4.0-supported region.
param location = 'swedencentral'

// Microsoft Entra tenant ID (Graph API authority).
param tenantId = '00000000-0000-0000-0000-000000000000'

// The SharePoint site the connector will monitor.
// (Grant this MI `Sites.Selected` on just this site — see
//  infra/grant-site-permission.ps1 — after deployment.)
param sharePointSiteUrl = 'https://yourcompany.sharepoint.com/sites/YourSite'

// Application (client) ID of the Entra app registration that represents the
// /api/search endpoint. Copilot Studio requests tokens for this audience via
// the OnKnowledgeRequested topic. Bare GUID OR an `api://<clientId>` URI.
param apiAudience = '00000000-0000-0000-0000-000000000000'
