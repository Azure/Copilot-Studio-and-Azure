using './main.bicep'

// ============================================================================
// Two required values — everything else is defaulted or created by the
// template itself (including the Entra app registration for /api/search,
// declared via the Microsoft Graph Bicep extension).
//
// `tenantId` is inferred from the deployment context (subscription().tenantId).
// `apiAudience` is generated during deployment and surfaced as an output.
// Everything else (Search SKU, Foundry, Document Intelligence, Key Vault,
// processing modes, concurrency, backup schedule, file extensions, etc.)
// is hardcoded in main.bicep and can be tuned post-deployment via Function
// App settings.
// ============================================================================

// Resource-name prefix (3–16 chars, lowercase letters / digits / hyphens).
// A short uniqueness hash is appended automatically where Azure demands
// globally-unique names (Search / Foundry / DocIntel / Storage / Key Vault).
param baseName = 'sp-indexer'

// Leave as-is to use the resource group's region, or pin to a specific
// Azure AI Vision multimodal-4.0-supported region.
param location = 'swedencentral'

// The SharePoint site the connector will monitor.
// (Grant the Function's managed identity `Sites.Selected` on just this
//  site via infra/grant-site-permission.ps1 after deployment.)
param sharePointSiteUrl = 'https://yourcompany.sharepoint.com/sites/YourSite'
