# ============================================================
# SharePoint → Azure AI Search Connector (Pattern A — unified multimodal)
# Copy this file to .env and fill in your values.
#
# AUTHENTICATION
#   All Azure calls use DefaultAzureCredential (managed identity in prod,
#   Azure CLI for local dev). Client secrets are an optional fallback for
#   Graph only, and the secret is resolved from Key Vault via the
#   @Microsoft.KeyVault(SecretUri=...) app-setting reference.
#
# REQUIRED RBAC ROLES (when using managed identity)
#   - Azure AI Search:       "Search Index Data Contributor" + "Search Service Contributor"
#   - Foundry / AI Services: "Cognitive Services User" (for Vision multimodal embeddings)
#   - Document Intel (opt):  "Cognitive Services User"
#   - Azure Storage:         "Blob Data Owner" + "Queue Data Contributor" + "Table Data Contributor"
#   - Key Vault (optional):  "Key Vault Secrets User"
#   - Graph API:             App registration with Sites.Read.All + Files.Read.All
#                            (or the least-privilege Sites.Selected alternative)
#   - Graph for /api/search: "GroupMember.Read.All" (application permission)
# ============================================================

# --- Microsoft Entra ID (for Graph API access to SharePoint) ---
TENANT_ID=your-tenant-id
# CLIENT_ID and CLIENT_SECRET are only needed if NOT using managed identity.
# In production, CLIENT_SECRET is a Key Vault reference — do not commit raw secrets.
CLIENT_ID=
CLIENT_SECRET=

# --- SharePoint Site ---
# For least-privilege, grant the Function App's managed identity Sites.Selected
# on just this one site (see infra/grant-site-permission.ps1).
SHAREPOINT_SITE_URL=https://yourcompany.sharepoint.com/sites/YourSite
# Optional: restrict to specific libraries by display name (comma-separated).
SHAREPOINT_LIBRARIES=
# Optional: further restrict to folder paths within each library.
# Paths are relative to the drive root. Empty = whole library.
# Example: "Finance/Reports,HR/Policies"
SHAREPOINT_ROOT_PATHS=

# --- Azure AI Search ---
SEARCH_ENDPOINT=https://your-search-service.search.windows.net
SEARCH_INDEX_NAME=sharepoint-index

# --- Azure AI Vision multimodal embeddings (Florence, 1024d) ---
# Single embedding service for the whole pipeline. Text chunks and image
# chunks end up in the same vector field (content_embedding).
# Point at a Foundry / Azure AI Services multi-service endpoint.
MULTIMODAL_ENDPOINT=https://your-foundry.cognitiveservices.azure.com
MULTIMODAL_MODEL_VERSION=2023-04-15
# Blob container for extracted image crops (citation thumbnails).
IMAGES_CONTAINER=images
# Set false to skip image handling entirely.
EXTRACT_IMAGES=true

# --- Document Intelligence (optional — Layout-aware extraction) ---
# Only helpful for PDF/DOCX/PPTX/XLSX (paragraph reading order, tables,
# figures with bounding boxes). Standalone image files (.png/.jpg/...) go
# direct to Azure AI Vision multimodal — DocIntel not needed for those.
# Leave empty to fall back to PyMuPDF / python-docx / python-pptx / openpyxl.
DOCINTEL_ENDPOINT=
DOCINTEL_SKIP_BELOW_KB=5
DOCINTEL_MAX_IMAGE_SIZE_MB=20

# --- Indexer Settings ---
INDEXED_EXTENSIONS=.pdf,.docx,.docm,.xlsx,.xlsm,.pptx,.pptm,.txt,.md,.csv,.json,.xml,.kml,.html,.htm,.rtf,.eml,.epub,.msg,.odt,.ods,.odp,.zip,.gz,.png,.jpg,.jpeg,.tiff,.bmp
CHUNK_SIZE=2000
CHUNK_OVERLAP=200
MAX_CONCURRENCY=4
MAX_FILE_SIZE_MB=500

# Per-file chunk vectorisation concurrency. Larger = faster initial seed,
# but subject to the Vision endpoint's rate limits.
VECTORISE_CONCURRENCY=8
# Global ceiling on in-flight Vision requests per Function instance.
# Raise only after confirming the Vision SKU can handle the TPS.
MULTIMODAL_MAX_IN_FLIGHT=8
# Every Nth run, run a full reconciliation scan for orphans (belt + braces
# behind the delta-query deletion handler). 0 = never.
RECONCILE_EVERY_N_RUNS=24

# --- Processing mode ---
# full             = process every file every run
# since-date       = process files modified at/after START_DATE
# since-last-run   = (default) watermark-driven; first run processes everything
PROCESSING_MODE=since-last-run
START_DATE=

# --- Function processing mode ---
# queue   = timer dispatches one queue message per file (scales to >50 files per run)
# inline  = legacy single-function
FUNCTION_PROCESSING_MODE=queue

# --- Schedule ---
INDEXER_SCHEDULE=0 0 * * * *

# --- Query-time security trimming (/api/search — called by the OnKnowledgeRequested topic) ---
# Expected audience for bearer tokens on /api/search. Set to the API app
# registration client ID (or App ID URI). Empty = endpoint disabled.
API_AUDIENCE=
# Optional comma-separated Entra object IDs always included in the identity list.
ALWAYS_ALLOWED_IDS=
IDENTITY_CACHE_TTL_SECONDS=300

# --- Index schema ---
# The index schema is provisioned by the Bicep deployment from
# infra/sharepoint-index.json. The Python application never creates,
# recreates, or updates the schema — it only reads/writes documents.
# To change the schema, edit infra/sharepoint-index.json and re-run deploy.ps1.

# --- Index backup ---
# CRON for the nightly backup (schema + docs + state → `backup` container).
BACKUP_SCHEDULE=0 0 3 * * *
BACKUP_CONTAINER=backup
BACKUP_RETENTION_DAYS=7

# --- State store (usually populated by Bicep; override only for local testing) ---
# AzureWebJobsStorage__accountName=<storage-account-name>
# STATE_CONTAINER=state
# INDEXER_QUEUE_NAME=sp-indexer-q
# FAILED_FILES_TABLE=failedFiles
# RUN_STATE_TABLE=runState
# WATERMARK_TABLE=watermark
