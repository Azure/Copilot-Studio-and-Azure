    "publishCode": {
      "type": "Microsoft.Resources/deploymentScripts",
      "apiVersion": "2023-08-01",
      "name": "[format('{0}-publish-code', parameters('baseName'))]",
      "location": "[parameters('location')]",
      "kind": "AzureCLI",
      "identity": {
        "type": "UserAssigned",
        "userAssignedIdentities": {
          "[format('{0}', resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', format('{0}-deployer-{1}', parameters('baseName'), variables('nameSuffix'))))]": {}
        }
      },
      "properties": {
        "azCliVersion": "2.65.0",
        "timeout": "PT30M",
        "retentionInterval": "PT1H",
        "cleanupPreference": "OnExpiration",
        "environmentVariables": [
          {
            "name": "PACKAGE_URL",
            "value": "[variables('packageReleaseUrl')]"
          },
          {
            "name": "FUNCTION_APP_HOSTNAME",
            "value": "[format('{0}.azurewebsites.net', variables('functionAppName'))]"
          }
        ],
        "scriptContent": "      set -eu\n      set -o pipefail\n\n      echo \"=== Downloading package zip from $PACKAGE_URL ===\"\n      curl -sSL --fail -o /tmp/package.zip \"$PACKAGE_URL\"\n      SIZE=$(stat -c%s /tmp/package.zip)\n      echo \"Downloaded $SIZE bytes\"\n\n      echo \"=== Acquiring management plane bearer token ===\"\n      TOKEN=$(az account get-access-token --resource https://management.azure.com --query accessToken -o tsv)\n\n      # Wait for the Flex front-end to come up (it returns 404 from\n      # /api/publish until the host is fully provisioned).\n      echo \"=== Waiting for https://$FUNCTION_APP_HOSTNAME/ to come up ===\"\n      READY=\"\"\n      for i in $(seq 1 30); do\n        PROBE=$(curl -sS -o /dev/null -w \"%{http_code}\" --max-time 10 \"https://$FUNCTION_APP_HOSTNAME/\" || echo \"000\")\n        echo \"Probe $i: HTTP $PROBE\"\n        if [ \"$PROBE\" != \"000\" ] && [ \"$PROBE\" -lt 500 ]; then\n          READY=\"yes\"\n          break\n        fi\n        sleep 10\n      done\n      if [ -z \"$READY\" ]; then\n        echo \"WARNING: front-end never responded < 500; will still try /api/publish\"\n      fi\n\n      echo \"=== POST https://$FUNCTION_APP_HOSTNAME/api/publish ===\"\n      # 10 attempts, 30s apart. 404 and 5xx are both retryable on Flex.\n      HTTP=\"\"\n      for i in $(seq 1 10); do\n        echo \"Attempt $i\"\n        HTTP=$(curl -sS -o /tmp/resp.txt -w \"%{http_code}\" \\\n               -X POST \"https://$FUNCTION_APP_HOSTNAME/api/publish\" \\\n               -H \"Authorization: Bearer $TOKEN\" \\\n               -H \"Content-Type: application/zip\" \\\n               --data-binary @/tmp/package.zip || echo \"000\")\n        echo \"HTTP $HTTP\"\n        if [ \"$HTTP\" = \"200\" ] || [ \"$HTTP\" = \"202\" ]; then\n          break\n        fi\n        echo \"Response body:\"; cat /tmp/resp.txt; echo\n        if [ \"$HTTP\" = \"401\" ] || [ \"$HTTP\" = \"403\" ]; then\n          echo \"ERROR: authentication failed (HTTP $HTTP). The deployer MI is missing 'Website Contributor' on the Function App.\" >&2\n          exit 1\n        fi\n        echo \"Sleeping 30s before retry\"\n        sleep 30\n      done\n\n      if [ \"$HTTP\" != \"200\" ] && [ \"$HTTP\" != \"202\" ]; then\n        echo \"ERROR: deploy failed (final HTTP $HTTP). Manual fallback: run 'func azure functionapp publish <function-app-name> --python --build remote'. See README S1.\" >&2\n        exit 1\n      fi\n      echo \"Package accepted by $FUNCTION_APP_HOSTNAME — Flex will recreate workers and sync triggers\"\n    "
      },
      "dependsOn": [
        "deployerIdentity",
        "deployerWebsiteRole",
        "functionApp"
      ]
    }
  },
