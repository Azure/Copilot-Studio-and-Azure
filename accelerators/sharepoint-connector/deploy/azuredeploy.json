        "enableSoftDelete": true,
        "softDeleteRetentionInDays": 7,
        "publicNetworkAccess": "Enabled"
      }
    },
    {
      "type": "Microsoft.ManagedIdentity/userAssignedIdentities",
      "apiVersion": "2023-01-31",
      "name": "[format('{0}-deployer-{1}', parameters('baseName'), variables('nameSuffix'))]",
      "location": "[parameters('location')]"
    },
    {
      "type": "Microsoft.Authorization/roleAssignments",
      "apiVersion": "2022-04-01",
      "scope": "[resourceId('Microsoft.Storage/storageAccounts', variables('storageName'))]",
      "name": "[guid(resourceId('Microsoft.Storage/storageAccounts', variables('storageName')), variables('storageBlobDataContributorRoleId'), resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', format('{0}-deployer-{1}', parameters('baseName'), variables('nameSuffix'))))]",
      "properties": {
        "roleDefinitionId": "[subscriptionResourceId('Microsoft.Authorization/roleDefinitions', variables('storageBlobDataContributorRoleId'))]",
        "principalId": "[reference(resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', format('{0}-deployer-{1}', parameters('baseName'), variables('nameSuffix'))), '2023-01-31').principalId]",
        "principalType": "ServicePrincipal"
      },
      "dependsOn": [
        "[resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', format('{0}-deployer-{1}', parameters('baseName'), variables('nameSuffix')))]",
        "[resourceId('Microsoft.Storage/storageAccounts', variables('storageName'))]"
      ]
    },
    {
      "type": "Microsoft.Resources/deploymentScripts",
      "apiVersion": "2023-08-01",
      "name": "[format('{0}-publish-code', parameters('baseName'))]",
      "location": "[parameters('location')]",
      "kind": "AzureCLI",
      "identity": {
        "type": "UserAssigned",
        "userAssignedIdentities": {
          "[format('{0}', resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', format('{0}-deployer-{1}', parameters('baseName'), variables('nameSuffix'))))]": {}
        }
      },
      "properties": {
        "azCliVersion": "2.65.0",
        "timeout": "PT10M",
        "retentionInterval": "PT1H",
        "cleanupPreference": "OnSuccess",
        "environmentVariables": [
          {
            "name": "STORAGE_ACCOUNT",
            "value": "[variables('storageName')]"
          },
          {
            "name": "CONTAINER",
            "value": "[variables('deployContainerName')]"
          },
          {
            "name": "PACKAGE_URL",
            "value": "[parameters('packageReleaseUrl')]"
          },
          {
            "name": "PACKAGE_BLOB",
            "value": "function-package.zip"
          }
        ],
        "scriptContent": "      set -eu\n      TEMP=$(mktemp -d)\n      cd \"$TEMP\"\n      echo \"Downloading $PACKAGE_URL\"\n      curl -sSL --fail -o package.zip \"$PACKAGE_URL\"\n      echo \"Uploading to $STORAGE_ACCOUNT/$CONTAINER/$PACKAGE_BLOB\"\n      az storage blob upload \\\n        --account-name \"$STORAGE_ACCOUNT\" \\\n        --container-name \"$CONTAINER\" \\\n        --name \"$PACKAGE_BLOB\" \\\n        --file package.zip \\\n        --auth-mode login \\\n        --overwrite\n      echo \"Upload complete.\"\n    "
      },
      "dependsOn": [
        "[resourceId('Microsoft.Storage/storageAccounts/blobServices/containers', variables('storageName'), 'default', variables('deployContainerName'))]",
        "[resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', format('{0}-deployer-{1}', parameters('baseName'), variables('nameSuffix')))]",
        "[extensionResourceId(resourceId('Microsoft.Storage/storageAccounts', variables('storageName')), 'Microsoft.Authorization/roleAssignments', guid(resourceId('Microsoft.Storage/storageAccounts', variables('storageName')), variables('storageBlobDataContributorRoleId'), resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', format('{0}-deployer-{1}', parameters('baseName'), variables('nameSuffix')))))]",
        "[resourceId('Microsoft.Storage/storageAccounts', variables('storageName'))]"
      ]
    },
    {
      "type": "Microsoft.Web/serverfarms",
      "apiVersion": "2024-04-01",
      "name": "[format('{0}-plan', parameters('baseName'))]",
      "location": "[parameters('location')]",
      "kind": "functionapp",
      "sku": {
        "tier": "FlexConsumption",
        "name": "FC1"
      },
      "properties": {
        "reserved": true
      }
    },
    {
      "type": "Microsoft.Web/sites",
      "apiVersion": "2024-04-01",
      "name": "[variables('functionAppName')]",
      "location": "[parameters('location')]",
      "kind": "functionapp,linux",
      "identity": {
        "type": "SystemAssigned"
      },
      "properties": {
        "serverFarmId": "[resourceId('Microsoft.Web/serverfarms', format('{0}-plan', parameters('baseName')))]",
        "httpsOnly": true,
        "functionAppConfig": {
          "deployment": {
            "storage": {
              "type": "blobContainer",
              "value": "[format('{0}{1}', reference(resourceId('Microsoft.Storage/storageAccounts', variables('storageName')), '2023-05-01').primaryEndpoints.blob, variables('deployContainerName'))]",
              "authentication": {
                "type": "SystemAssignedIdentity"
              }
            }
          },
          "scaleAndConcurrency": {
            "maximumInstanceCount": 40,
            "instanceMemoryMB": "[variables('instanceMemoryMB')]"
          },
          "runtime": {
            "name": "python",
            "version": "3.11"
          }
        },
        "siteConfig": {
          "appSettings": [
            {
              "name": "AzureWebJobsStorage__accountName",
              "value": "[variables('storageName')]"
            },
            {
              "name": "AzureWebJobsStorage__credential",
              "value": "managedidentity"
            },
            {
              "name": "FUNCTIONS_EXTENSION_VERSION",
              "value": "~4"
            },
            {
              "name": "APPLICATIONINSIGHTS_CONNECTION_STRING",
              "value": "[reference(resourceId('Microsoft.Insights/components', variables('appInsightsName')), '2020-02-02').ConnectionString]"
            },
            {
              "name": "TENANT_ID",
              "value": "[parameters('tenantId')]"
            },
            {
              "name": "SHAREPOINT_SITE_URL",
              "value": "[parameters('sharePointSiteUrl')]"
            },
            {
              "name": "SHAREPOINT_LIBRARIES",
              "value": "[variables('sharePointLibraries')]"
            },
            {
              "name": "SHAREPOINT_ROOT_PATHS",
              "value": "[variables('sharePointRootPaths')]"
            },
            {
              "name": "SEARCH_ENDPOINT",
              "value": "[variables('searchEndpoint')]"
            },
            {
              "name": "SEARCH_INDEX_NAME",
              "value": "[variables('searchIndexName')]"
            },
            {
              "name": "INDEXED_EXTENSIONS",
              "value": "[variables('indexedExtensions')]"
            },
            {
              "name": "INDEXER_SCHEDULE",
              "value": "[variables('indexerSchedule')]"
            },
            {
              "name": "PROCESSING_MODE",
              "value": "[variables('processingMode')]"
            },
            {
              "name": "START_DATE",
              "value": "[variables('startDate')]"
            },
            {
              "name": "FUNCTION_PROCESSING_MODE",
              "value": "[variables('functionProcessingMode')]"
            },
            {
              "name": "MAX_FILE_SIZE_MB",
              "value": "[string(variables('maxFileSizeMb'))]"
            },
            {
              "name": "MAX_CONCURRENCY",
              "value": "4"
            },
            {
              "name": "CHUNK_SIZE",
              "value": "2000"
            },
            {
              "name": "CHUNK_OVERLAP",
              "value": "200"
            },
            {
              "name": "VECTORISE_CONCURRENCY",
              "value": "[string(variables('vectoriseConcurrency'))]"
            },
            {
              "name": "MULTIMODAL_MAX_IN_FLIGHT",
              "value": "[string(variables('multimodalMaxInFlight'))]"
            },
            {
              "name": "RECONCILE_EVERY_N_RUNS",
              "value": "[string(variables('reconcileEveryNRuns'))]"
            },
            {
              "name": "STATE_CONTAINER",
              "value": "[variables('stateContainerName')]"
            },
            {
              "name": "INDEXER_QUEUE_NAME",
              "value": "[variables('indexerQueueName')]"
            },
            {
              "name": "FAILED_FILES_TABLE",
              "value": "[variables('failedFilesTableName')]"
            },
            {
              "name": "RUN_STATE_TABLE",
              "value": "[variables('runStateTableName')]"
            },
            {
              "name": "WATERMARK_TABLE",
              "value": "[variables('watermarkTableName')]"
            },
            {
              "name": "BACKUP_SCHEDULE",
              "value": "[variables('backupSchedule')]"
            },
            {
              "name": "BACKUP_CONTAINER",
              "value": "[variables('backupContainerName')]"
            },
            {
              "name": "BACKUP_RETENTION_DAYS",
              "value": "[string(variables('backupRetentionDays'))]"
            },
            {
              "name": "MULTIMODAL_ENDPOINT",
              "value": "[variables('foundryEndpoint')]"
            },
            {
              "name": "MULTIMODAL_MODEL_VERSION",
              "value": "[variables('multimodalModelVersion')]"
            },
            {
              "name": "DOCINTEL_ENDPOINT",
              "value": "[variables('docIntelEndpoint')]"
            },
            {
              "name": "IMAGES_CONTAINER",
              "value": "[variables('imagesContainerName')]"
            },
            {
              "name": "EXTRACT_IMAGES",
              "value": "[if(variables('extractImages'), 'true', 'false')]"
            },
            {
              "name": "FORCE_RECREATE_INDEX",
              "value": "[if(variables('forceRecreateIndex'), 'true', 'false')]"
            },
            {
              "name": "API_AUDIENCE",
              "value": "[parameters('apiAudience')]"
            },
            {
              "name": "ALWAYS_ALLOWED_IDS",
              "value": "[variables('alwaysAllowedIds')]"
            },
            {
              "name": "KEY_VAULT_URI",
              "value": "[reference(resourceId('Microsoft.KeyVault/vaults', variables('keyVaultName')), '2023-07-01').vaultUri]"
            }
          ]
        }
      },
      "dependsOn": [
        "[resourceId('Microsoft.Insights/components', variables('appInsightsName'))]",
        "[resourceId('Microsoft.Web/serverfarms', format('{0}-plan', parameters('baseName')))]",
        "[resourceId('Microsoft.KeyVault/vaults', variables('keyVaultName'))]",
