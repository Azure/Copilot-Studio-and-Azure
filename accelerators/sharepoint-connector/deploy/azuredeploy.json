    "storageName": "[toLower(format('{0}st{1}', replace(parameters('baseName'), '-', ''), variables('nameSuffix')))]",
    "appInsightsName": "[format('{0}-insights', parameters('baseName'))]",
    "logAnalyticsName": "[format('{0}-logs', parameters('baseName'))]",
    "keyVaultName": "[take(format('{0}-kv-{1}', parameters('baseName'), variables('nameSuffix')), 24)]",
    "searchServiceName": "[take(toLower(format('{0}-search-{1}', parameters('baseName'), variables('nameSuffix'))), 60)]",
    "foundryAccountName": "[take(format('{0}-foundry-{1}', parameters('baseName'), variables('nameSuffix')), 60)]",
    "docIntelName": "[take(format('{0}-docintel-{1}', parameters('baseName'), variables('nameSuffix')), 60)]",
    "deployContainerName": "app-package",
    "stateContainerName": "state",
    "backupContainerName": "backup",
    "indexerQueueName": "sp-indexer-q",
    "indexerPoisonQueueName": "sp-indexer-q-poison",
    "failedFilesTableName": "failedFiles",
    "runStateTableName": "runState",
    "watermarkTableName": "watermark",
    "foundryEndpoint": "[format('https://{0}.cognitiveservices.azure.com', variables('foundryAccountName'))]",
    "docIntelEndpoint": "[format('https://{0}.cognitiveservices.azure.com', variables('docIntelName'))]",
    "searchEndpoint": "[format('https://{0}.search.windows.net', variables('searchServiceName'))]",
    "searchDataContributorRoleId": "8ebe5a00-799e-43f5-93ac-243d3dce84a7",
    "searchServiceContributorRoleId": "7ca78c08-252a-4471-8644-bb5ff32d4ba0",
    "cognitiveServicesUserRoleId": "a97b65f3-24c7-4388-baec-2e87135dc908",
    "storageBlobDataOwnerRoleId": "b7e6dc6d-f1e8-4753-8033-0f276bb0955b",
    "storageBlobDataContributorRoleId": "ba92f5b4-2d11-453d-a403-e96b0029c9fe",
    "storageAccountContributorRoleId": "17d1049b-9a84-46fb-8f53-869881c3d3ab",
    "storageQueueDataContributorRoleId": "974c5e8b-45b9-4653-ba55-5f855dd0fb88",
    "storageTableDataContributorRoleId": "0a9a7e1f-b9d0-4cc4-a60d-0319b160aaa3",
    "keyVaultSecretsUserRoleId": "4633458b-17de-408a-b874-0445c86b69e6"
  },
  "resources": [
    {
