      "apiVersion": "2023-05-01",
      "name": "[format('{0}/{1}/{2}', variables('storageName'), 'default', variables('indexerPoisonQueueName'))]",
      "dependsOn": [
        "[resourceId('Microsoft.Storage/storageAccounts/queueServices', variables('storageName'), 'default')]"
      ]
    },
    {
      "type": "Microsoft.Storage/storageAccounts/tableServices",
      "apiVersion": "2023-05-01",
      "name": "[format('{0}/{1}', variables('storageName'), 'default')]",
      "dependsOn": [
