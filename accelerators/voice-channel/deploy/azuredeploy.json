      "defaultValue": "gpt-realtime-mini",
      "allowedValues": [
        "gpt-realtime",
        "gpt-realtime-mini"
      ],
      "metadata": {
        "description": "Voice Live model used for real-time streaming (used by the server before create-foundry-agent.ps1 runs)."
      }
    },
    "voiceName": {
      "type": "string",
      "defaultValue": "en-US-Ava:DragonHDLatestNeural",
