                },
                {
                  "name": "MCS_AGENT_NAME",
                  "value": "[parameters('mcsAgentName')]"
                }
              ]
            }
          ],
          "scale": {
            "minReplicas": 1,
            "maxReplicas": 3,
            "rules": [
              {
                "name": "http-scaler",
                "http": {
                  "metadata": {
                    "concurrentRequests": "20"
                  }
                }
              }
            ]
          }
        }
      },
      "dependsOn": [
        "[resourceId('Microsoft.ContainerRegistry/registries', variables('acrName'))]",
        "[extensionResourceId(resourceId('Microsoft.ContainerRegistry/registries', variables('acrName')), 'Microsoft.Authorization/roleAssignments', guid(resourceId('Microsoft.ContainerRegistry/registries', variables('acrName')), variables('acrPullRoleId'), resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', variables('managedIdentityName'))))]",
        "[resourceId('Microsoft.Insights/components', variables('appInsightsName'))]",
        "[resourceId('Microsoft.App/managedEnvironments', variables('caeName'))]",
        "[resourceId('Microsoft.CognitiveServices/accounts', variables('foundryName'))]",
        "[resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', variables('managedIdentityName'))]"
      ]
    },
    {
      "type": "Microsoft.Resources/deploymentScripts",
      "apiVersion": "2023-08-01",
      "name": "[format('{0}-build-image', parameters('environmentName'))]",
      "location": "[parameters('location')]",
      "kind": "AzureCLI",
      "identity": {
        "type": "UserAssigned",
        "userAssignedIdentities": {
          "[format('{0}', resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', variables('managedIdentityName')))]": {}
        }
      },
      "properties": {
        "azCliVersion": "2.60.0",
        "retentionInterval": "PT1H",
        "timeout": "PT30M",
        "cleanupPreference": "OnSuccess",
        "environmentVariables": [
          {
            "name": "ACR_NAME",
            "value": "[variables('acrName')]"
          },
          {
            "name": "GIT_URL",
            "value": "[parameters('gitSourceUrl')]"
          },
          {
            "name": "GIT_BRANCH",
            "value": "[parameters('gitBranch')]"
          },
          {
            "name": "IMAGE_TAG",
            "value": "[format('{0}/voice-channel/server:initial', reference(resourceId('Microsoft.ContainerRegistry/registries', variables('acrName')), '2023-11-01-preview').loginServer)]"
          },
          {
            "name": "APP_NAME",
            "value": "[variables('containerAppName')]"
          },
          {
            "name": "RG",
            "value": "[resourceGroup().name]"
          }
        ],
        "scriptContent": "      set -euo pipefail\n      echo \"=== Building server image via ACR Tasks ===\"\n      echo \"  registry : $ACR_NAME\"\n      echo \"  git      : $GIT_URL @ $GIT_BRANCH\"\n      echo \"  image    : $IMAGE_TAG\"\n\n      # --source accepts: <repo>#<branch>:<subpath>\n      # Dockerfile lives at accelerators/voice-channel/server/Dockerfile with context rooted there.\n      az acr build \\\n        --registry \"$ACR_NAME\" \\\n        --image voice-channel/server:initial \\\n        --file Dockerfile \\\n        --source \"${GIT_URL}#${GIT_BRANCH}:accelerators/voice-channel/server\"\n\n      echo \"=== Updating Container App to the built image ===\"\n      az containerapp update \\\n        --resource-group \"$RG\" \\\n        --name \"$APP_NAME\" \\\n        --image \"$IMAGE_TAG\"\n    "
      },
      "dependsOn": [
        "[resourceId('Microsoft.ContainerRegistry/registries', variables('acrName'))]",
        "[extensionResourceId(resourceId('Microsoft.ContainerRegistry/registries', variables('acrName')), 'Microsoft.Authorization/roleAssignments', guid(resourceId('Microsoft.ContainerRegistry/registries', variables('acrName')), variables('acrPushRoleId'), resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', variables('managedIdentityName'))))]",
        "[resourceId('Microsoft.App/containerApps', variables('containerAppName'))]",
        "[resourceId('Microsoft.Authorization/roleAssignments', guid(resourceGroup().id, variables('contributorRoleId'), resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', variables('managedIdentityName'))))]",
        "[resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', variables('managedIdentityName'))]"
      ]
    },
    {
      "condition": "[variables('provisionMcs')]",
      "type": "Microsoft.Resources/deploymentScripts",
      "apiVersion": "2023-08-01",
      "name": "[format('{0}-provision-mcs', parameters('environmentName'))]",
      "location": "[parameters('location')]",
      "kind": "AzurePowerShell",
      "identity": {
        "type": "UserAssigned",
        "userAssignedIdentities": {
          "[format('{0}', resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', variables('managedIdentityName')))]": {}
        }
      },
      "properties": {
        "azPowerShellVersion": "11.5",
        "retentionInterval": "PT1H",
        "timeout": "PT30M",
        "cleanupPreference": "OnSuccess",
        "environmentVariables": [
          {
            "name": "PP_ENV_URL",
            "value": "[parameters('powerPlatformEnvironmentUrl')]"
          },
          {
            "name": "SP_TENANT",
            "value": "[parameters('entraTenantId')]"
          },
          {
            "name": "SP_CLIENT",
            "value": "[parameters('powerPlatformSpnClientId')]"
          },
          {
            "name": "SP_SECRET",
            "secureValue": "[parameters('powerPlatformSpnClientSecret')]"
          },
          {
            "name": "AGENT_NAME",
            "value": "[parameters('mcsAgentName')]"
          },
          {
            "name": "SCHEMA_NAME",
            "value": "microsoft_learn_assistant"
          },
          {
            "name": "KV_NAME",
            "value": "[variables('keyVaultName')]"
          },
          {
            "name": "SECRET_NAME",
            "value": "[variables('directLineSecretName')]"
          }
        ],
        "scriptContent": "      $ErrorActionPreference = 'Stop'\n\n      Write-Host \"=== Installing pac CLI ===\" -ForegroundColor Cyan\n      try { dotnet tool install --global Microsoft.PowerApps.CLI.Tool | Out-Null } catch { }\n      $env:PATH = \"$env:PATH\" + [IO.Path]::PathSeparator + \"$HOME/.dotnet/tools\"\n\n      Write-Host \"`n=== pac auth via SPN ===\" -ForegroundColor Cyan\n      pac auth create `\n        --name 'oneclick' `\n        --tenant \"$env:SP_TENANT\" `\n        --applicationId \"$env:SP_CLIENT\" `\n        --clientSecret \"$env:SP_SECRET\" `\n        --environment \"$env:PP_ENV_URL\"\n\n      $agentYaml = @\"\nschemaVersion: \"1.0\"\nkind: DeclarativeAgent\nname: \"$env:AGENT_NAME\"\ndescription: Answers Microsoft product and IT-pro questions using Microsoft Learn.\ninstructions: |\n  You are the Microsoft Learn Assistant. Every answer must be grounded in\n  results from the Microsoft Learn MCP tool. Call microsoft_docs_search first,\n  optionally follow up with microsoft_docs_fetch. Cite Learn article titles\n  inline. Keep answers under 6 sentences.\naiSettings:\n  generativeMode: enabled\n  temperature: 0.3\ntools:\n  - kind: ModelContextProtocolTool\n    name: \"Microsoft Learn MCP\"\n    server:\n      transport: streamableHttp\n      url: \"https://learn.microsoft.com/api/mcp\"\n      authentication:\n        type: none\nchannels:\n  directLine:\n    enabled: true\n  microsoftTeams:\n    enabled: false\n\"@\n      Set-Content -Path ./agent.yaml -Value $agentYaml -Encoding UTF8\n\n      Write-Host \"`n=== Creating agent ===\" -ForegroundColor Cyan\n      $created = $false\n      try {\n        pac copilot create --file ./agent.yaml --name \"$env:AGENT_NAME\" --schema-name \"$env:SCHEMA_NAME\"\n        if ($LASTEXITCODE -eq 0) { $created = $true }\n      } catch { }\n      if (-not $created) {\n        pac copilot new --name \"$env:AGENT_NAME\" --schema-name \"$env:SCHEMA_NAME\"\n        pac copilot update --schema-name \"$env:SCHEMA_NAME\" --file ./agent.yaml\n      }\n\n      Write-Host \"`n=== Publishing ===\" -ForegroundColor Cyan\n      pac copilot publish --schema-name \"$env:SCHEMA_NAME\"\n\n      Write-Host \"`n=== Enabling Direct Line ===\" -ForegroundColor Cyan\n      pac copilot channel enable --schema-name \"$env:SCHEMA_NAME\" --channel directLine\n      $secretJson = pac copilot channel show-secret --schema-name \"$env:SCHEMA_NAME\" --channel directLine --output json\n      $secret = ($secretJson | ConvertFrom-Json).secret\n      if (-not $secret) { throw 'Failed to capture Direct Line secret.' }\n\n      Write-Host \"`n=== Writing secret to Key Vault ===\" -ForegroundColor Cyan\n      az login --identity | Out-Null\n      az keyvault secret set `\n        --vault-name \"$env:KV_NAME\" `\n        --name \"$env:SECRET_NAME\" `\n        --value \"$secret\" | Out-Null\n\n      $DeploymentScriptOutputs = @{\n        agentName  = $env:AGENT_NAME\n        schemaName = $env:SCHEMA_NAME\n      }\n      Write-Host \"`n=== Done ===\" -ForegroundColor Green\n    "
      },
      "dependsOn": [
        "[resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', variables('managedIdentityName'))]",
        "[resourceId('Microsoft.KeyVault/vaults', variables('keyVaultName'))]",
        "[extensionResourceId(resourceId('Microsoft.KeyVault/vaults', variables('keyVaultName')), 'Microsoft.Authorization/roleAssignments', guid(resourceId('Microsoft.KeyVault/vaults', variables('keyVaultName')), variables('keyVaultSecretsOfficerRoleId'), resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', variables('managedIdentityName'))))]"
      ]
    }
  ],
  "outputs": {
    "AZURE_LOCATION": {
      "type": "string",
      "value": "[parameters('location')]"
    },
    "AZURE_TENANT_ID": {
      "type": "string",
      "value": "[subscription().tenantId]"
    },
    "AZURE_RESOURCE_GROUP": {
      "type": "string",
      "value": "[resourceGroup().name]"
    },
    "AZURE_CONTAINER_REGISTRY_ENDPOINT": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.ContainerRegistry/registries', variables('acrName')), '2023-11-01-preview').loginServer]"
    },
    "AZURE_CONTAINER_REGISTRY_NAME": {
      "type": "string",
      "value": "[variables('acrName')]"
    },
    "AZURE_CONTAINER_APP_NAME": {
      "type": "string",
      "value": "[variables('containerAppName')]"
    },
    "AZURE_CONTAINER_APP_FQDN": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.App/containerApps', variables('containerAppName')), '2024-03-01').configuration.ingress.fqdn]"
    },
    "FOUNDRY_NAME": {
      "type": "string",
      "value": "[variables('foundryName')]"
    },
    "FOUNDRY_ENDPOINT": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.CognitiveServices/accounts', variables('foundryName')), '2024-10-01').endpoint]"
    },
    "FOUNDRY_RESOURCE_ID": {
      "type": "string",
      "value": "[resourceId('Microsoft.CognitiveServices/accounts', variables('foundryName'))]"
    },
    "KEY_VAULT_NAME": {
      "type": "string",
      "value": "[variables('keyVaultName')]"
    },
    "KEY_VAULT_URI": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.KeyVault/vaults', variables('keyVaultName')), '2024-04-01-preview').vaultUri]"
    },
    "DIRECTLINE_SECRET_NAME": {
      "type": "string",
      "value": "[variables('directLineSecretName')]"
    },
    "MANAGED_IDENTITY_CLIENT_ID": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', variables('managedIdentityName')), '2023-01-31').clientId]"
    },
    "MCS_PROVISIONED": {
      "type": "bool",
      "value": "[variables('provisionMcs')]"
    }
  }
}