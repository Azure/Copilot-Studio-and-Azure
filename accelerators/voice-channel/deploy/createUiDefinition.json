{
    "$schema": "https://schema.management.azure.com/schemas/0.1.2-preview/CreateUIDefinition.MultiVm.json#",
    "handler": "Microsoft.Azure.CreateUIDef",
    "version": "0.1.2-preview",
    "parameters": {
        "basics": [
            {
                "name": "baseName",
                "type": "Microsoft.Common.TextBox",
                "label": "Base name",
                "toolTip": "3-18 lowercase chars, no spaces. Seeds the Foundry custom domain and App Service hostname.",
                "constraints": {
                    "required": true,
                    "regex": "^[a-z][a-z0-9-]{2,17}$",
                    "validationMessage": "Must be 3-18 chars, lowercase, start with a letter, digits and single hyphens allowed."
                }
            }
        ],
        "steps": [
            {
                "name": "voiceLive",
                "label": "Voice Live (IT Assistant)",
                "elements": [
                    {
                        "name": "voiceLiveModel",
                        "type": "Microsoft.Common.DropDown",
                        "label": "Voice Live model",
                        "defaultValue": "gpt-realtime-mini (basic)",
                        "toolTip": "Pro = gpt-realtime / gpt-5. Basic = *-mini. Lite = gpt-5-nano / phi4-*. Pricing: https://learn.microsoft.com/azure/ai-services/speech-service/voice-live#pricing",
                        "constraints": {
                            "allowedValues": [
                                { "label": "gpt-realtime-mini (basic)",  "value": "gpt-realtime-mini" },
                                { "label": "gpt-realtime (pro)",         "value": "gpt-realtime" },
                                { "label": "gpt-4.1-mini (basic)",       "value": "gpt-4.1-mini" },
                                { "label": "gpt-4.1 (pro)",              "value": "gpt-4.1" },
                                { "label": "gpt-5-mini (basic)",         "value": "gpt-5-mini" },
                                { "label": "gpt-5 (pro)",                "value": "gpt-5" },
                                { "label": "gpt-5-nano (lite)",          "value": "gpt-5-nano" },
                                { "label": "phi4-mini (lite)",           "value": "phi4-mini" }
                            ]
                        }
                    },
                    {
                        "name": "voiceName",
                        "type": "Microsoft.Common.DropDown",
                        "label": "TTS voice",
                        "defaultValue": "Ava (HD, en-US)",
                        "toolTip": "Azure neural voice used for spoken output.",
                        "constraints": {
                            "allowedValues": [
                                { "label": "Ava (HD, en-US)",     "value": "en-US-Ava:DragonHDLatestNeural" },
                                { "label": "Andrew (HD, en-US)",  "value": "en-US-Andrew:DragonHDLatestNeural" },
                                { "label": "Ava (en-US)",         "value": "en-US-AvaNeural" },
                                { "label": "Jenny (en-US)",       "value": "en-US-JennyNeural" },
                                { "label": "Guy (en-US)",         "value": "en-US-GuyNeural" }
                            ]
                        }
                    },
                    {
                        "name": "appServicePlanSku",
                        "type": "Microsoft.Common.DropDown",
                        "label": "App Service plan SKU",
                        "defaultValue": "B1 (dev)",
                        "constraints": {
                            "allowedValues": [
                                { "label": "B1 (dev)",   "value": "B1" },
                                { "label": "B2",         "value": "B2" },
                                { "label": "P1v3 (prod)","value": "P1v3" },
                                { "label": "P2v3",       "value": "P2v3" }
                            ]
                        }
                    }
                ]
            },
            {
                "name": "copilotStudio",
                "label": "Copilot Studio (Microsoft Learn Assistant)",
                "elements": [
                    {
                        "name": "info",
                        "type": "Microsoft.Common.InfoBox",
                        "visible": true,
                        "options": {
                            "icon": "Info",
                            "text": "If you fill these fields, the deployment will automatically create the Copilot Studio agent and wire the Direct Line secret into the App Service. Otherwise, leave blank and run copilot-studio-agent/create-agent.ps1 manually after deployment."
                        }
                    },
                    {
                        "name": "mcsAgentName",
                        "type": "Microsoft.Common.TextBox",
                        "label": "Agent display name",
                        "defaultValue": "Microsoft Learn Assistant",
                        "toolTip": "The Copilot Studio agent name shown in Teams / M365.",
                        "constraints": {
                            "required": true
                        }
                    },
                    {
                        "name": "powerPlatformEnvironmentUrl",
                        "type": "Microsoft.Common.TextBox",
                        "label": "Power Platform environment URL",
                        "defaultValue": "",
                        "toolTip": "Full URL, e.g. https://contoso.crm.dynamics.com. Leave empty to skip MCS provisioning.",
                        "constraints": {
                            "required": false,
                            "regex": "^$|^https://[^\\s]+\\.(crm|crm\\d+)\\.dynamics\\.com/?$",
                            "validationMessage": "Must be a https://<env>.crm*.dynamics.com URL, or empty."
                        }
                    },
                    {
                        "name": "powerPlatformSpnClientId",
                        "type": "Microsoft.Common.TextBox",
                        "label": "Service principal client ID (GUID)",
                        "defaultValue": "",
                        "toolTip": "Entra SPN with 'Application User' in the PP env + Dataverse System Admin role.",
                        "constraints": {
                            "required": false,
                            "regex": "^$|^[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{12}$",
                            "validationMessage": "Must be a GUID, or empty."
                        }
                    },
                    {
                        "name": "powerPlatformSpnClientSecret",
                        "type": "Microsoft.Common.PasswordBox",
                        "label": { "password": "Service principal secret", "confirmPassword": "Confirm secret" },
                        "toolTip": "Client secret for the SPN above.",
                        "constraints": { "required": false },
                        "options": { "hideConfirmation": true }
                    }
                ]
            }
        ],
        "outputs": {
            "baseName":                      "[basics('baseName')]",
            "location":                      "[location()]",
            "voiceLiveModel":                "[steps('voiceLive').voiceLiveModel]",
            "voiceName":                     "[steps('voiceLive').voiceName]",
            "appServicePlanSku":             "[steps('voiceLive').appServicePlanSku]",
            "mcsAgentName":                  "[steps('copilotStudio').mcsAgentName]",
            "powerPlatformEnvironmentUrl":   "[steps('copilotStudio').powerPlatformEnvironmentUrl]",
            "powerPlatformSpnClientId":      "[steps('copilotStudio').powerPlatformSpnClientId]",
            "powerPlatformSpnClientSecret":  "[steps('copilotStudio').powerPlatformSpnClientSecret]"
        }
    }
}
